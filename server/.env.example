# Copy to .env and fill in. Never commit .env.

PORT=4000

# --- Notion (single workspace: TIGFBAO + Master Task List Table) ---
NOTION_TOKEN=
NOTION_PROJECTS_DB=
NOTION_TASKS_DB=

# Optional: a Notion page with "Skyline: ..." and "Nudge: ..." lines that a
# scheduled Claude task rewrites; the dashboard shows that copy when present.
NOTION_NARRATIVE_PAGE=

# --- Google Calendar (OAuth, read-only) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
