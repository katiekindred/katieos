# Copy to .env and fill in. Never commit .env.

PORT=4000

# --- Notion (single workspace: TIGFBAO + Master Task List Table) ---
NOTION_TOKEN=
NOTION_PROJECTS_DB=
NOTION_TASKS_DB=

# Optional: two Notion pages a scheduled Claude task can rewrite. Their body
# text is read verbatim (lines starting with `<!--` are treated as guidance
# comments and skipped) and shown in place of the app's built-in copy.
NOTION_SKYLINE_PAGE=
NOTION_NUDGE_PAGE=

# --- Google Calendar (OAuth, read-only) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
